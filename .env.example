# AuditAI Backend Configuration
# Copy this to .env and fill in your values

# App
DEBUG=true

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auditai

# Redis (for Celery task queue)
REDIS_URL=redis://localhost:6379/0

# Auth
SECRET_KEY=change-me-to-a-random-secret-in-production

# OAuth — Google
# The redirect URI (OAUTH_REDIRECT_URL) is sent to Google as-is (no query params).
# The provider name is passed via the OAuth 2.0 `state` parameter.
# This means the redirect URI registered in the console must match EXACTLY.
#
# Register in Google Cloud Console:
#   APIs & Services > Credentials > {your OAuth 2.0 Client ID} >
#   Authorized redirect URIs.
#
# Add BOTH:
#   - http://localhost:8000/api/v1/auth/callback
#   - https://securithm.vercel.app/_/backend/api/v1/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:8000/api/v1/auth/callback

# OAuth — GitHub
# Same approach as Google — the `state` parameter carries "github" so the
# redirect_uri stays clean and matches exactly what's registered.
#
# Register in GitHub OAuth App settings:
#   Settings > Developer settings > OAuth Apps > {your App}
#   Authorization callback URL.
#
# Add (one at a time, GitHub only supports one callback URL per app):
#   - http://localhost:8000/api/v1/auth/callback (local dev)
#   - https://securithm.vercel.app/_/backend/api/v1/auth/callback (production)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# External APIs
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Sentry (error tracking)
SENTRY_DSN=

# Frontend: GitHub repo for CI status indicator
# NEXT_PUBLIC_GITHUB_OWNER=your-org
# NEXT_PUBLIC_GITHUB_REPO=auditai
