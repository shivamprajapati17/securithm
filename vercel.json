{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "installCommand": "npm install && python3 -m pip install -r requirements.txt",
  "regions": [
    "iad1"
  ],
  "github": {
    "silent": true
  },
  "rewrites": [
    {
      "source": "/api/v1/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
