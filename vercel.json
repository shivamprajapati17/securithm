{
  "name": "securithm",
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "regions": [
    "iad1"
  ],
  "github": {
    "silent": true
  },
  "experimentalServices": {
    "frontend": {
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "main:app",
      "routePrefix": "/_/backend"
    }
  }
}
